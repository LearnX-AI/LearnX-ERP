<odoo>

    <record id="view_employee_form_faculty" model="ir.ui.view">
        <field name="name">hr.employee.form.faculty</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>

        <field name="arch" type="xml">

            <xpath expr="//notebook" position="inside">

                <page string="Faculty Info">

                    <group>
                        <field name="faculty_department_id"/>
                        <field name="faculty_employee_id"/>
                        <field name="contract_type"/>
                    </group>

                    <group>
                        <field name="qualifications"/>
                        <field name="expertise_subjects"/>
                    </group>

                </page>

            </xpath>

        </field>
    </record>

</odoo>